# Ключи облачных провайдеров для LLM-перевода и timing_fit.
# Не коммитьте реальные значения. Скопируйте файл в .env или экспортируйте
# переменные в окружении сервера.

GEMINI_API_KEY=
GEMINI_TRANSLATION_MODEL=gemini-2.5-flash-lite
GEMINI_REWRITE_MODEL=gemini-2.5-flash-lite
# Если задан — Gemini использует OpenAI-совместимый мост (например litellm proxy).
# Мост авторизуется сам, ключ не нужен. Для Docker: host.docker.internal:5000
GEMINI_BRIDGE_URL=

OPENROUTER_API_KEY=
# Укажите конкретную бесплатную модель из OpenRouter Models.
OPENROUTER_TRANSLATION_MODEL=openai/gpt-oss-20b:free
OPENROUTER_REWRITE_MODEL=openai/gpt-oss-20b:free
OPENROUTER_SITE_URL=http://localhost:8002
OPENROUTER_APP_NAME=translateVideo

AIHUBMIX_API_KEY=
AIHUBMIX_BASE_URL=https://aihubmix.com/v1
AIHUBMIX_TRANSLATION_MODEL=gemini-3-flash-preview-free
AIHUBMIX_REWRITE_MODEL=gpt-4.1-nano-free

# Polza.ai платный агрегатор. Ключ можно хранить в .env, но провайдер
# включается только при явном *_ALLOW_PAID_FALLBACK=true.
POLZA_API_KEY=
POLZA_BASE_URL=https://api.polza.ai/api/v1
POLZA_TRANSLATION_MODEL=google/gemini-2.5-flash-lite-preview-09-2025
POLZA_REWRITE_MODEL=google/gemini-2.5-flash-lite-preview-09-2025
TRANSLATION_ALLOW_PAID_FALLBACK=false
REWRITE_ALLOW_PAID_FALLBACK=false

# Прокси только для облачных LLM-запросов (обходит блокировки Gemini API в РФ).
# НЕ системный прокси — его читают только translation/cloud.py и timing/cloud.py.
# Пример: http://127.0.0.1:10808 (Hiddify/Xray на хосте)
TRANSLATION_PROXY=
REWRITER_PROXY=

# Общий timeout одного запроса LLM-переводчика.
# При 429/503/timeout провайдер уходит в cooldown, а не выключается навсегда.
TRANSLATION_PROVIDER_TIMEOUT=15

# Общий timeout одного запроса rewriter-провайдера.
# При 429/503/timeout провайдер уходит в cooldown, а не выключается навсегда.
REWRITE_PROVIDER_TIMEOUT=8

# RPM-лимиты задаются в project.json через translation_provider_rpm/rewrite_provider_rpm.
# Дефолт: 5 RPM для бесплатных Gemini/OpenRouter/AIHubMix и 30 RPM для Polza.ai.

# ── Логирование ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
#LOG_FILE=/app/logs/app.log
LOG_FILE=
