# Ключи облачных rewriter-провайдеров для timing_fit.
# Не коммитьте реальные значения. Скопируйте файл в .env или экспортируйте
# переменные в окружении сервера.

GEMINI_API_KEY=
GEMINI_REWRITE_MODEL=gemini-2.5-flash-lite

OPENROUTER_API_KEY=
# Укажите конкретную бесплатную модель из OpenRouter Models.
OPENROUTER_REWRITE_MODEL=openai/gpt-oss-120b:free
OPENROUTER_SITE_URL=http://localhost:8002
OPENROUTER_APP_NAME=translateVideo

AIHUBMIX_API_KEY=
AIHUBMIX_BASE_URL=https://aihubmix.com/v1
AIHUBMIX_REWRITE_MODEL=gemini-3-flash-preview-free

# Polza.ai платный агрегатор, поэтому он стоит последним fallback.
POLZA_API_KEY=
POLZA_BASE_URL=https://api.polza.ai/api/v1
POLZA_REWRITE_MODEL=google/gemini-2.5-flash-lite-preview-09-2025
